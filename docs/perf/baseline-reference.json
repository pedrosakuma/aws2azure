    "azure-sdk.ServiceBus.SendMessage (256 B, queue)":             { "minThroughputPerSec":  50.0, "maxP99Ms":  500.0 },
    "azure-sdk.ServiceBus.ReceiveMessage+Complete (1)":            { "minThroughputPerSec":   5.0, "maxP99Ms": 2000.0 },

