    "s3.PutObject (4 KiB)":                                        { "minThroughputPerSec":  50.0, "maxP99Ms":  500.0 },
    "s3.GetObject (64 KiB)":                                       { "minThroughputPerSec": 100.0, "maxP99Ms":  500.0 },
    "azure-sdk.Blob.UploadAsync (4 KiB)":                          { "minThroughputPerSec":  50.0, "maxP99Ms":  500.0 },

